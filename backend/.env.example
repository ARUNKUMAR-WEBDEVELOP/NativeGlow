SECRET_KEY=your-django-secret-key-here-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-render-host.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.com

# Database (Supabase/Render)
# Preferred: set full DATABASE_URL from Supabase/Render
# Example: postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
DATABASE_URL=

# Optional fallback (use only if DATABASE_URL is not set)
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=db.xxxxx.supabase.co
DB_PORT=5432
DB_SSLMODE=require

GOOGLE_CLIENT_ID=your-google-client-id-from-console.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-from-console