{
  "info": {
    "_postman_id": "vendor-auth-api-collection",
    "name": "NativeGlow Vendor Auth API",
    "description": "Collection for testing vendor authentication endpoints",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Register Vendor",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"full_name\": \"John Doe\",\n  \"email\": \"john@organicfarms.com\",\n  \"password\": \"SecurePass123!\",\n  \"confirm_password\": \"SecurePass123!\",\n  \"business_name\": \"Organic Farms Co.\",\n  \"whatsapp_number\": \"+919876543210\",\n  \"city\": \"Mumbai\",\n  \"upi_id\": \"john@upi\",\n  \"bank_account_number\": \"1234567890\",\n  \"bank_ifsc\": \"SBIN0001234\",\n  \"account_holder_name\": \"John Doe\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/vendor/register/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "vendor", "register", ""]
        },
        "description": "Register a new vendor account. Password is auto-hashed, vendor_slug is auto-generated."
      },
      "response": []
    },
    {
      "name": "2. Login Vendor",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john@organicfarms.com\",\n  \"password\": \"SecurePass123!\"\n}"
        },
        "url": {
          "raw": "http://localhost:8000/api/vendor/login/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "vendor", "login", ""]
        },
        "description": "Login with email and password. Returns JWT access and refresh tokens."
      },
      "response": []
    },
    {
      "name": "3. Get Vendor Profile",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{access_token}}",
            "description": "JWT access token from login response"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "http://localhost:8000/api/vendor/me/",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8000",
          "path": ["api", "vendor", "me", ""]
        },
        "description": "Get authenticated vendor's profile. Requires JWT access token."
      },
      "response": []
    },
    {
      "name": "Test Cases",
      "item": [
        {
          "name": "Invalid Email Format",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Smith\",\n  \"email\": \"invalid-email\",\n  \"password\": \"SecurePass123!\",\n  \"confirm_password\": \"SecurePass123!\",\n  \"business_name\": \"Smith Organics\",\n  \"whatsapp_number\": \"+919876543210\",\n  \"city\": \"Delhi\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/register/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "register", ""]
            },
            "description": "Test: Should fail with invalid email format error"
          },
          "response": []
        },
        {
          "name": "Password Mismatch",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Smith\",\n  \"email\": \"jane@organics.com\",\n  \"password\": \"SecurePass123!\",\n  \"confirm_password\": \"DifferentPass123!\",\n  \"business_name\": \"Smith Organics\",\n  \"whatsapp_number\": \"+919876543210\",\n  \"city\": \"Delhi\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/register/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "register", ""]
            },
            "description": "Test: Should fail with password mismatch error"
          },
          "response": []
        },
        {
          "name": "Duplicate Email",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"John Duplicate\",\n  \"email\": \"john@organicfarms.com\",\n  \"password\": \"SecurePass123!\",\n  \"confirm_password\": \"SecurePass123!\",\n  \"business_name\": \"Different Farm\",\n  \"whatsapp_number\": \"+919876543210\",\n  \"city\": \"Bangalore\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/register/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "register", ""]
            },
            "description": "Test: Should fail with duplicate email error (if email already exists)"
          },
          "response": []
        },
        {
          "name": "Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@organicfarms.com\",\n  \"password\": \"WrongPassword123!\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/login/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "login", ""]
            },
            "description": "Test: Should fail with invalid credentials error"
          },
          "response": []
        },
        {
          "name": "Profile Without Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:8000/api/vendor/me/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "me", ""]
            },
            "description": "Test: Should fail with 401 Unauthorized (no token provided)"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token from login response"
    },
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string"
    }
  ]
}
