                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Title\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/products/99999/edit/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "products", "99999", "edit", ""]
            },
            "description": "Test: Should fail with 404 - product not found"
          },
          "response": []
        },
        {
          "name": "Update Quantity - Negative Value",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"available_quantity\": -10\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/products/1/quantity/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "products", "1", "quantity", ""]
            },
            "description": "Test: Should fail with 400 - quantity must be non-negative"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
