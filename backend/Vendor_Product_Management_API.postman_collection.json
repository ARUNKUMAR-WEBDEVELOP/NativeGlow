            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Missing title field\",\n  \"category_type\": \"face_wash\",\n  \"price\": \"299.00\",\n  \"available_quantity\": 50\n}"
            },
            "url": {
              "raw": "http://localhost:8000/api/vendor/products/add/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "products", "add", ""]
            },
            "description": "Test: Should fail with 400 - title required"
          },
          "response": []
        },
        {
          "name": "List Products - No Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/vendor/products/",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "vendor", "products", ""]
            },
            "description": "Test: Should fail with 401 - token required"
          },
          "response": []
        },
        {
          "name": "Edit Non-existent Product",
          "request": {
            "method": "PUT",
            "header": [
              {
